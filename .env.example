# ==========================================================================
# booster-dashboard — 환경 변수 예시
# 실제 값은 .env.local (gitignored) 또는 Vercel Environment Variables 에 주입.
# ==========================================================================

# ───── GA4 (Google Analytics 4 Data API) ─────
GA4_PROPERTY_ID=

# 인증 (1) 서비스 계정 JSON 문자열 직접 주입
# GCP 조직에 iam.disableServiceAccountKeyCreation 정책이 있으면 사용 불가 →
# 아래 Workload Identity Federation 으로 전환할 것
GCP_SA_KEY_JSON=

# 인증 (2) Workload Identity Federation (Vercel OIDC 사용 — 권장)
GCP_PROJECT_NUMBER=
GCP_WORKLOAD_IDENTITY_POOL_ID=
GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=
GCP_SERVICE_ACCOUNT_EMAIL=

# ───── Microsoft Clarity ─────
# Project dashboard 상단 URL 또는 Settings 에서 확인
CLARITY_PROJECT_ID=
# Settings → Data export → Generate new API token (Admin 권한 필요)
CLARITY_API_TOKEN=

# ───── 매체 광고 API (사내 IP 222.109.27.119 에서만 직접 호출 허용) ─────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

META_ADS_ACCESS_TOKEN=
META_ADS_AD_ACCOUNT_ID=

NAVER_SEARCHAD_API_KEY=
NAVER_SEARCHAD_SECRET_KEY=
NAVER_SEARCHAD_CUSTOMER_ID=

KAKAO_MOMENT_ACCESS_TOKEN=
KAKAO_MOMENT_AD_ACCOUNT_ID=

TIKTOK_ADS_ACCESS_TOKEN=
TIKTOK_ADS_ADVERTISER_ID=

DANGGEUN_BIZ_API_BASE=
DANGGEUN_BIZ_ACCESS_TOKEN=
DANGGEUN_BIZ_ACCOUNT_ID=

# IP 가드 — 이 값이 사내 허가 IP(222.109.27.119)와 일치할 때만 실 매체 API 호출
SERVER_PUBLIC_IP=

# ───── Phase 2 예정 ─────
# 헤이픽·리드프로 리드 DB 접근 정보 (접근 경로 확정 후)
# LEADS_DATABASE_URL=

# ───── AI 기능 ─────
# Google Generative AI (Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=
